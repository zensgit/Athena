# ===========================================
# Athena ECM — Environment Variables Template
# ===========================================
# Copy this file:  cp .env.example .env
# Then edit values as needed for your environment.

# -------------------------------------------
# PostgreSQL (ECM primary database)
# -------------------------------------------
POSTGRES_DB=ecm_db
POSTGRES_USER=ecm_user
POSTGRES_PASSWORD=ecm_password
POSTGRES_PORT=5432

# -------------------------------------------
# Redis
# -------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6390
REDIS_PASSWORD=redis_password

# -------------------------------------------
# RabbitMQ
# -------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=rabbitmq
RABBITMQ_PASSWORD=rabbitmq_password

# -------------------------------------------
# Elasticsearch
# -------------------------------------------
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# -------------------------------------------
# MinIO (Object Storage)
# -------------------------------------------
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key
MINIO_BUCKET=ecm-documents
MINIO_PORT=9205
MINIO_CONSOLE_PORT=9206

# -------------------------------------------
# Keycloak (Identity Provider)
# -------------------------------------------
KEYCLOAK_USER=admin
KEYCLOAK_PASSWORD=admin
KEYCLOAK_PORT=8180
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak_password

# -------------------------------------------
# Odoo (ERP Integration)
# -------------------------------------------
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=odoo_password
ODOO_ADMIN_PASSWORD=admin_password

# -------------------------------------------
# ML Service
# -------------------------------------------
ML_SERVICE_URL=http://ml-service:8080

# -------------------------------------------
# WPS Online Editor (optional; disabled by default)
# -------------------------------------------
ECM_WPS_ENABLED=false
ECM_WPS_APPID=
ECM_WPS_APPKEY=
ECM_WPS_DOMAIN=https://wwo.wps.cn/office/
ECM_API_BASE_URL=

# -------------------------------------------
# Collabora Online (open-source editor via WOPI)
# -------------------------------------------
COLLABORA_PORT=9980
COLLABORA_DOMAIN=localhost
COLLABORA_ADMIN_USER=admin
COLLABORA_ADMIN_PASSWORD=admin

# -------------------------------------------
# WOPI Integration
# -------------------------------------------
ECM_WOPI_ENABLED=true
ECM_WOPI_DISCOVERY_URL=http://collabora:9980/hosting/discovery
ECM_WOPI_PUBLIC_URL=http://localhost:5500
ECM_WOPI_HOST_URL=http://ecm-core:8080

# -------------------------------------------
# Application
# -------------------------------------------
JWT_SECRET=mySecretKey_athena_ecm_core_2025
ECM_API_PORT=7700
ECM_FRONTEND_PORT=5500

# -------------------------------------------
# Optional Feature Toggles
# -------------------------------------------
ECM_OCR_ENABLED=false
ECM_OCR_ENRICH_CORRESPONDENT_ENABLED=false
ECM_PREVIEW_CAD_ENABLED=true
ECM_PREVIEW_CAD_RENDER_URL=http://host.docker.internal:18001/api/v1/render/cad
ECM_PREVIEW_CAD_TIMEOUT_MS=30000
JODCONVERTER_LOCAL_ENABLED=true
JODCONVERTER_LOCAL_OFFICE_HOME=/Applications/LibreOffice.app/Contents
