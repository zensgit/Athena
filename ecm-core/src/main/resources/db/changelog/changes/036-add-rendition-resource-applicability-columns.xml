<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="036-add-rendition-resource-applicability-columns" author="codex">
        <addColumn tableName="rendition_resources">
            <column name="applicable" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="applicability_reason" type="varchar(256)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
