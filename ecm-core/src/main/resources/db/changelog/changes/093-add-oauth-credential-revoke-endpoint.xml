<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="093-add-oauth-credential-revoke-endpoint" author="codex">
        <comment>Add optional CUSTOM OAuth provider revoke endpoint</comment>

        <addColumn tableName="oauth_credentials">
            <column name="revoke_endpoint" type="varchar(512)"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="oauth_credentials" columnName="revoke_endpoint"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
