<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="031-add-preview-failure-ledger-columns" author="codex">
        <addColumn tableName="documents">
            <column name="preview_failure_count" type="int"/>
            <column name="preview_failed_at" type="timestamp"/>
            <column name="preview_last_failure_reason" type="text"/>
            <column name="preview_failure_content_hash" type="varchar(128)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
