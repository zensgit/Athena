<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="047-create-site-members-table" author="codex">
        <comment>Create site_members table for site membership roster</comment>

        <createTable tableName="site_members">
            <column name="id" type="${uuid_type}" defaultValueComputed="${uuid_function}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="site_id" type="${uuid_type}">
                <constraints nullable="false" foreignKeyName="fk_sm_site" references="sites(id)"/>
            </column>
            <column name="username" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="varchar(20)" defaultValue="CONSUMER">
                <constraints nullable="false"/>
            </column>
            <column name="joined_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="site_members"
            columnNames="site_id, username"
            constraintName="uq_site_member"/>

        <createIndex tableName="site_members" indexName="idx_sm_site_id">
            <column name="site_id"/>
        </createIndex>
        <createIndex tableName="site_members" indexName="idx_sm_username">
            <column name="username"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
