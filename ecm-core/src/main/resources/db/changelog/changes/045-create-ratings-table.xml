<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="045-create-ratings-table" author="codex">
        <comment>Create ratings table for likes and five-star ratings</comment>

        <createTable tableName="ratings">
            <column name="id" type="${uuid_type}" defaultValueComputed="${uuid_function}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="node_id" type="${uuid_type}">
                <constraints nullable="false" foreignKeyName="fk_rating_node" references="nodes(id)"/>
            </column>
            <column name="user_id" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="scheme" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="score" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="ratings"
            columnNames="node_id, user_id, scheme"
            constraintName="uq_rating_node_user_scheme"/>

        <createIndex tableName="ratings" indexName="idx_rating_node_id">
            <column name="node_id"/>
        </createIndex>
        <createIndex tableName="ratings" indexName="idx_rating_user_id">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="ratings" indexName="idx_rating_scheme">
            <column name="scheme"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
