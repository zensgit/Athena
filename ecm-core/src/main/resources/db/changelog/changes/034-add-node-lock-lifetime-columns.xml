<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="034-add-node-lock-lifetime-columns" author="codex">
        <addColumn tableName="nodes">
            <column name="lock_lifetime" type="varchar(32)"/>
            <column name="lock_expires_at" type="timestamp"/>
        </addColumn>

        <createIndex tableName="nodes" indexName="idx_nodes_lock_expires_at">
            <column name="lock_expires_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
