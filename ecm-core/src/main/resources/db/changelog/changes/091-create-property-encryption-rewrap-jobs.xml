<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="091-create-property-encryption-rewrap-jobs" author="codex">
        <comment>Property encryption rewrap job ledger foundation</comment>

        <createTable tableName="property_encryption_rewrap_jobs">
            <column name="id" type="${uuid_type}" defaultValueComputed="${uuid_function}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="status" type="varchar(32)" defaultValue="PLANNED">
                <constraints nullable="false"/>
            </column>
            <column name="target_key_version" type="varchar(100)"/>
            <column name="requested_by" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="requested_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
            <column name="started_at" type="timestamp"/>
            <column name="finished_at" type="timestamp"/>
            <column name="candidate_node_count" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="encrypted_property_value_count" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="values_already_on_target_key_count" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="values_requiring_rewrap_count" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="unversioned_or_malformed_value_count" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="processed_value_count" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="rewrapped_value_count" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="skipped_value_count" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="failed_value_count" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="key_version_counts" type="jsonb" defaultValueComputed="'[]'::jsonb"/>
            <column name="missing_source_key_versions" type="jsonb" defaultValueComputed="'[]'::jsonb"/>
            <column name="warnings" type="jsonb" defaultValueComputed="'[]'::jsonb"/>
            <column name="last_error" type="varchar(2000)"/>
            <column name="created_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp"/>
            <column name="version" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="property_encryption_rewrap_jobs" indexName="idx_prop_enc_rewrap_job_status">
            <column name="status"/>
        </createIndex>

        <createIndex tableName="property_encryption_rewrap_jobs" indexName="idx_prop_enc_rewrap_job_requested">
            <column name="requested_at"/>
        </createIndex>

        <rollback>
            <dropTable tableName="property_encryption_rewrap_jobs"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
