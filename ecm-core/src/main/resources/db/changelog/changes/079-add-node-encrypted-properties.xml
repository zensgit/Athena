<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="079-add-node-encrypted-properties" author="kernel-hardening">
        <comment>PR-11B: add encrypted property definitions and encrypted node property storage</comment>

        <addColumn tableName="property_definitions">
            <column name="encrypted" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="nodes">
            <column name="encrypted_properties" type="jsonb"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="nodes" columnName="encrypted_properties"/>
            <dropColumn tableName="property_definitions" columnName="encrypted"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
