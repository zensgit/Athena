<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.17.xsd">

    <changeSet id="060-create-transfer-replication-tables" author="codex">
        <createTable tableName="transfer_targets">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(200)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="target_folder_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="replication_definitions">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(200)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="source_node_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="transfer_target_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="include_children" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="last_run_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="replication_jobs">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="definition_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="transfer_target_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="source_node_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="copied_node_id" type="UUID"/>
            <column name="user_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="last_message" type="TEXT"/>
            <column name="error_log" type="TEXT"/>
            <column name="started_at" type="TIMESTAMP"/>
            <column name="completed_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <createIndex tableName="transfer_targets" indexName="idx_transfer_target_name">
            <column name="name"/>
        </createIndex>
        <createIndex tableName="transfer_targets" indexName="idx_transfer_target_folder_id">
            <column name="target_folder_id"/>
        </createIndex>
        <createIndex tableName="replication_definitions" indexName="idx_replication_definition_name">
            <column name="name"/>
        </createIndex>
        <createIndex tableName="replication_definitions" indexName="idx_replication_definition_source">
            <column name="source_node_id"/>
        </createIndex>
        <createIndex tableName="replication_definitions" indexName="idx_replication_definition_target">
            <column name="transfer_target_id"/>
        </createIndex>
        <createIndex tableName="replication_jobs" indexName="idx_replication_job_definition_id">
            <column name="definition_id"/>
        </createIndex>
        <createIndex tableName="replication_jobs" indexName="idx_replication_job_target_id">
            <column name="transfer_target_id"/>
        </createIndex>
        <createIndex tableName="replication_jobs" indexName="idx_replication_job_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="replication_jobs" indexName="idx_replication_job_created_at">
            <column name="created_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
