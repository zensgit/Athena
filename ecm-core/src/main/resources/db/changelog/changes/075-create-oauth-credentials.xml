<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="075-create-oauth-credentials-table" author="kernel-hardening">
        <comment>P3 PR-12B: First-class generic OAuth credential aggregate</comment>

        <createTable tableName="oauth_credentials">
            <column name="id" type="${uuid_type}" defaultValueComputed="${uuid_function}">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="owner_type" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="owner_id" type="${uuid_type}">
                <constraints nullable="false"/>
            </column>
            <column name="provider" type="varchar(32)"/>
            <column name="token_endpoint" type="varchar(512)"/>
            <column name="tenant_id" type="varchar(255)"/>
            <column name="scope" type="text"/>
            <column name="credential_key" type="varchar(255)"/>
            <column name="access_token" type="text"/>
            <column name="refresh_token" type="text"/>
            <column name="token_expires_at" type="timestamp"/>
            <column name="created_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp"/>
        </createTable>

        <addUniqueConstraint
            tableName="oauth_credentials"
            columnNames="owner_type, owner_id"
            constraintName="uq_oauth_credential_owner"/>

        <createIndex tableName="oauth_credentials" indexName="idx_oauth_credential_owner_type">
            <column name="owner_type"/>
        </createIndex>

        <createIndex tableName="oauth_credentials" indexName="idx_oauth_credential_credential_key">
            <column name="credential_key"/>
        </createIndex>

        <rollback>
            <dropTable tableName="oauth_credentials"/>
        </rollback>
    </changeSet>

    <changeSet id="075-backfill-mail-oauth-credentials" author="kernel-hardening">
        <comment>P3 PR-12B: Backfill generic OAuth credentials from existing mail_accounts rows</comment>

        <sql>
            INSERT INTO oauth_credentials (
                id,
                owner_type,
                owner_id,
                provider,
                token_endpoint,
                tenant_id,
                scope,
                credential_key,
                access_token,
                refresh_token,
                token_expires_at,
                created_at,
                updated_at
            )
            SELECT
                gen_random_uuid(),
                'MAIL_ACCOUNT',
                ma.id,
                ma.oauth_provider,
                ma.oauth_token_endpoint,
                ma.oauth_tenant_id,
                ma.oauth_scope,
                ma.oauth_credential_key,
                ma.oauth_access_token,
                ma.oauth_refresh_token,
                ma.oauth_token_expires_at,
                COALESCE(ma.created_date, now()),
                COALESCE(ma.last_modified_date, ma.created_date, now())
            FROM mail_accounts ma
            WHERE ma.is_deleted = false
              AND ma.security = 'OAUTH2'
              AND NOT EXISTS (
                    SELECT 1
                    FROM oauth_credentials oc
                    WHERE oc.owner_type = 'MAIL_ACCOUNT'
                      AND oc.owner_id = ma.id
                )
        </sql>
    </changeSet>

</databaseChangeLog>
