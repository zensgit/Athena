<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <changeSet id="042-add-node-type-qname-column" author="codex">
        <comment>Add content-model type qualified name column to nodes table</comment>

        <addColumn tableName="nodes">
            <column name="type_qname" type="varchar(200)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <createIndex tableName="nodes" indexName="idx_nodes_type_qname">
            <column name="type_qname"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
